# ── Runtime / 產生的檔案 ──────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Secrets（絕對不進 repo）────────────────────────────────────────────────
.env
*.env
!.env.example

# ── Runtime state（放 workspace memory/，不放 skill/）────────────────────
# tiege-queue.json 等執行期狀態檔應放在：
# $WORKSPACE_DIR/memory/x-knowledge-base/tiege-queue.json

# ── 臨時 / 系統檔案 ──────────────────────────────────────────────────────
.DS_Store
*.swp
*.swo
/tmp/
vector_index.json

# ── Secrets 目錄（*.env 等敏感副檔名忽略，*.example 可進 repo）──────────────
.secrets/*.env
.secrets/*.key
.secrets/*.secret
.secrets/*.pem

# ── PM2 runtime JSON（含真實路徑等機器相關設定）─────────────────────────────
# 如需版控，改用 *.pm2.example.json 作模板
