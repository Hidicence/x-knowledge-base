# ══════════════════════════════════════════════════════
# x-knowledge-base 環境變數設定範例
# 使用方式：複製此檔案為 .env 或填入你的 shell profile
# ══════════════════════════════════════════════════════

# ── 必填：X / Twitter 認證 ──────────────────────────
# 從瀏覽器 Cookie 取得（登入 x.com 後從開發者工具複製）
BIRD_AUTH_TOKEN=
BIRD_CT0=

# ── 選填：推薦腳本的 Twitter 認證 ──────────────────
# 若未提供，會自動回退使用上方的 BIRD_AUTH_TOKEN / BIRD_CT0
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# ── 選填：AI 摘要（MiniMax API）───────────────────
# 不設定則自動改用 OpenClaw fallback 或本地規則式摘要
MINIMAX_API_KEY=
MINIMAX_ENDPOINT=https://api.minimax.io/anthropic/v1/messages
MINIMAX_MODEL=MiniMax-M2.5

# ── 選填：OpenClaw fallback 設定 ──────────────────
# 當 MINIMAX_API_KEY 為空時，嘗試走 OpenClaw agent
OPENCLAW_MINIMAX_FALLBACK=1
OPENCLAW_MINIMAX_SESSION=xkb-summarizer
OPENCLAW_MINIMAX_AGENT=

# ── 選填：路徑設定 ────────────────────────────────
# 預設值已可直接使用，通常不需要修改
# WORKSPACE_DIR=~/.openclaw/workspace
# BOOKMARKS_DIR=~/.openclaw/workspace/memory/bookmarks

# ── 選填：Google Drive 同步 ───────────────────────
# 需安裝 rclone 並設定好遠端名稱
RCLONE_REMOTE=your-drive-remote:XKnowledgeBase-Bookmarks

# ── 選填：個人化設定 ──────────────────────────────
# 你的名字，會出現在知識卡的「對 XXX 的價值」欄位
XKB_USER_NAME=User

# ── 選填：Tiege queue 路徑 ────────────────────────
# 預設放在 WORKSPACE_DIR/memory/x-knowledge-base/tiege-queue.json
# XKB_QUEUE_PATH=

# ── 可選：語意向量搜尋 v3 ────────────────────────────────────────────────────
# 設定後執行 python3 scripts/build_vector_index.py 建立向量索引
# 之後可用 --semantic flag 啟用語意召回：
#   python3 scripts/recall_for_conversation.py "你的問題" --semantic
#
# 支援的 Provider：
#   gemini  → 需要 GEMINI_API_KEY（推薦，text-embedding-004 幾乎免費）
#   openai  → 需要 OPENAI_API_KEY（text-embedding-3-small）
#   ollama  → 需要本地 Ollama（nomic-embed-text，完全免費）
#
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=text-embedding-004
# GEMINI_API_KEY=your_gemini_key_here
# OPENAI_API_KEY=your_openai_key_here
# OLLAMA_BASE_URL=http://localhost:11434

# ── 選填：YouTube 播放清單整合 ───────────────────────────────────────────────
# 設定一個「知識庫專用」公開播放清單，系統每日自動抓取新影片字幕並生成知識卡
# 
# 步驟：
#   1. 在 YouTube 建立一個公開播放清單（建議命名：知識庫 / Knowledge Base）
#   2. 貼上播放清單 URL（格式：https://www.youtube.com/playlist?list=PLxxx）
#   3. 匯出 YouTube cookies（Chrome 安裝「Get cookies.txt LOCALLY」插件）
#   4. 上傳 cookies 至 VPS：scp cookies.txt server:~/.config/yt-dlp/cookies.txt
#   5. 執行測試：python3 scripts/fetch_youtube_playlist.py --dry-run
#
# YOUTUBE_PLAYLIST_URL=https://www.youtube.com/playlist?list=PLxxx
