# x-knowledge-base environment

# Required for X bookmarks fetch
BIRD_AUTH_TOKEN=
BIRD_CT0=

# Optional for AI summarization
MINIMAX_API_KEY=
MINIMAX_ENDPOINT=https://api.minimax.io/anthropic/v1/messages
MINIMAX_MODEL=MiniMax-M2.5

# Optional: if MINIMAX_API_KEY is empty, fallback to OpenClaw routed model
OPENCLAW_MINIMAX_FALLBACK=1
OPENCLAW_MINIMAX_MODEL=minimax/MiniMax-M2.5
OPENCLAW_MINIMAX_SESSION=xkb-summarizer
