{
  "apps": [
    {
      "name": "xkb-memory-distill-chunk-worker",
      "script": "python3",
      "args": "scripts/distill_memory_chunk_worker.py --poll-interval 15",
      "cwd": ".",
      "autorestart": true,
      "restart_delay": 10000,
      "max_restarts": 10,
      "log_file": "/tmp/xkb-memory-distill-chunk-worker.log",
      "error_file": "/tmp/xkb-memory-distill-chunk-worker-err.log"
    }
  ]
}